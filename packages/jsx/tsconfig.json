{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "jsx": "preserve",
    "jsxFactory": "elementFactory",
    "jsxFragmentFactory": "fragmentFactory"
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules"]
}
